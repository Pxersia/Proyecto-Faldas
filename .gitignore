*.log
*.tmp
*.bak
*.swp

# Archivos del sistema
.DS_Store
Thumbs.db

# Variables de entorno y configuraciones locales
.env
application-local.properties

# Archivos generados automáticamente
*.jar
*.war
*.ear

# Archivos de pruebas generados
test-output/
